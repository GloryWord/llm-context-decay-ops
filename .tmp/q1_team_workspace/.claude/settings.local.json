{
    "permissions": {
        "defaultMode": "bypassPermissions",
        "allow": [
            "Bash(*)",
            "Write(*)",
            "Edit(*)",
            "Read(*)",
            "WebFetch",
            "WebSearch"
        ],
        "deny": [
            "Bash(rm -rf *)",
            "Bash(sudo *)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/eval_gate.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}
