+def build_summary(
+    *,
+    records: list[dict[str, Any]],
+    condition_rows: list[dict[str, Any]],
+    order_rows: list[dict[str, Any]],
+    trace_counts: dict[str, Any],
+    judge_audit: dict[str, Any],
+    outputs: dict[str, str],
+) -> dict[str, Any]:
+    """Build a compact machine-readable summary for reports."""
+    lookup = _condition_lookup(condition_rows)
+    adversarial_target_success = [
+        row["targeted_rule_success_mean"]
+        for row in condition_rows
+        if row["attack_intensity"] == "adversarial" and row["targeted_rule_success_mean"] is not None
+    ]
+    adversarial_perfect_success = [
+        row["perfect_success_mean"]
+        for row in condition_rows
+        if row["attack_intensity"] == "adversarial" and row["perfect_success_mean"] is not None
+    ]
+    benign_perfect = [
+        row["perfect_success_mean"]
+        for row in condition_rows
+        if row["attack_intensity"] == "benign" and row["perfect_success_mean"] is not None
+    ]
+    non_target = [
+        row["non_target_failure_mean"]
+        for row in condition_rows
+        if row["attack_intensity"] == "adversarial" and row["non_target_failure_mean"] is not None
+    ]
+    gaps: list[float] = []
+    for rule_count in RULE_COUNTS:
+        for turn_count in TURN_COUNTS:
+            benign = lookup.get((rule_count, turn_count, "benign"), {}).get("perfect_success_mean")
+            adversarial = lookup.get((rule_count, turn_count, "adversarial"), {}).get("perfect_success_mean")
+            if benign is not None and adversarial is not None:
+                gaps.append(float(benign) - float(adversarial))
+
+    order_pair_rows = [
+        row
+        for row in order_rows
+        if row["attack_order_variant"] in {"implicit_then_adversarial", "adversarial_then_implicit"}
+    ]
+    order_old_rates = {
+        row["attack_order_variant"]: []
+        for row in order_pair_rows
+    }
+    for row in order_pair_rows:
+        value = row.get("per_rule_pass_rate_mean")
+        if value is not None:
+            order_old_rates[row["attack_order_variant"]].append(float(value))
+
+    target_rule_counts = dict(Counter(str(r.get("target_rule_id", "")) for r in records))
+
+    return {
+        "records": len(records),
+        "jsonl_records_by_attack_intensity": dict(Counter(str(r.get("attack_intensity", "")) for r in records)),
+        "jsonl_records_by_attack_order_variant": dict(Counter(str(r.get("attack_order_variant", "")) for r in records)),
+        "trace_rows": trace_counts["rows"],
+        "trace_rows_by_condition": dict(trace_counts["condition"]),
+        "trace_sampled_variant_count": len(trace_counts["sampled_variant_id"]),
+        "target_rule_ids": target_rule_counts,
+        "target_rule_scope": describe_target_rule_scope(target_rule_counts),
+        "rule_counts": dict(Counter(str(r.get("rule_count", "")) for r in records)),
+        "turn_counts": dict(Counter(str(r.get("turn_count", "")) for r in records)),
+        "mean_benign_perfect_success": mean(benign_perfect) if benign_perfect else None,
+        "mean_adversarial_perfect_success": mean(adversarial_perfect_success) if adversarial_perfect_success else None,
+        "mean_adversarial_targeted_rule_success": mean(adversarial_target_success) if adversarial_target_success else None,
+        "mean_adversarial_non_target_failure": mean(non_target) if non_target else None,
+        "mean_benign_minus_adversarial_gap": mean(gaps) if gaps else None,
+        "attack_order_old_per_rule_pass_mean": {
+            order: mean(values) if values else None for order, values in order_old_rates.items()
+        },
+        "judge_audit": {
+            "candidate_rows": judge_audit.get("candidate_rows"),
+            "human_only_rows": judge_audit.get("human_only_rows"),
+            "changed_score_cells": judge_audit.get("changed_score_cells"),
+            "source_result_sha256": judge_audit.get("source_result_sha256"),
+            "ai_adjusted_jsonl_sha256": judge_audit.get("ai_adjusted_jsonl_sha256"),
+        },
+        "outputs": outputs,
+    }
+
+
+def write_markdown_summary(path: Path, summary: dict[str, Any]) -> Path:
+    """Write a concise human-readable summary for downstream reports."""
+    target_scope = summary.get("target_rule_scope", {})
+    title = (
+        "# Q1 target-balanced visualization summary"
+        if target_scope.get("is_q2_available_target_balanced")
+        else "# Q1 sampled-injection visualization summary"
+    )
+    lines = [
+        title,
+        "",
+        "## Data integrity",
+        f"- Enriched result records: {summary['records']}",
+        f"- Trace CSV rows: {summary['trace_rows']}",
+        f"- Target rule scope: {target_scope.get('label', 'unknown')}",
+        f"- Target rule distribution: `{summary['target_rule_ids']}`",
+        f"- Attack-order variants: `{summary['jsonl_records_by_attack_order_variant']}`",
+        "- Judge audit changed score cells: "
+        f"{summary['judge_audit']['changed_score_cells']}; "
+        f"human_only rows: {summary['judge_audit']['human_only_rows']}",
+        "",
+        "## Key descriptive results",
+        f"- Mean benign strict perfect_success across condition cells: {pct(summary['mean_benign_perfect_success'])}",
+        f"- Mean adversarial strict perfect_success across condition cells: {pct(summary['mean_adversarial_perfect_success'])}",
+        f"- Mean adversarial targeted rule success: {pct(summary['mean_adversarial_targeted_rule_success'])}",
+        f"- Mean adversarial non-target failure: {pct(summary['mean_adversarial_non_target_failure'])}",
+        f"- Mean benign−adversarial strict gap: {summary['mean_benign_minus_adversarial_gap'] * 100:.1f}pp"
+        if summary["mean_benign_minus_adversarial_gap"] is not None
+        else "- Mean benign−adversarial strict gap: N/A",
+        "",
+        "## Outputs",
+    ]
+    for label, output in summary["outputs"].items():
+        lines.append(f"- {label}: `{output}`")
+    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return path
+
+
+def parse_args() -> argparse.Namespace:
+    """Parse CLI arguments."""
+    parser = argparse.ArgumentParser(description="Create Q1 sampled-injection visualizations.")
+    parser.add_argument("--input", type=Path, default=DEFAULT_INPUT)
+    parser.add_argument("--trace", type=Path, default=DEFAULT_TRACE)
+    parser.add_argument("--judge-audit", type=Path, default=DEFAULT_JUDGE_AUDIT)
+    parser.add_argument("--output-dir", type=Path, default=DEFAULT_OUTPUT_DIR)
+    return parser.parse_args()
+
+
+def main() -> None:
+    """Run visualization pipeline."""
+    args = parse_args()
+    output_dir = args.output_dir
+    figures_dir = output_dir / "figures"
+    tables_dir = output_dir / "tables"
+    output_dir.mkdir(parents=True, exist_ok=True)
+    figures_dir.mkdir(parents=True, exist_ok=True)
+    tables_dir.mkdir(parents=True, exist_ok=True)
+
+    records = load_jsonl(args.input)
+    trace_counts = load_trace_counts(args.trace)
+    judge_audit = json.loads(args.judge_audit.read_text(encoding="utf-8"))
+
+    condition_rows = build_condition_rows(records)
+    order_rows = build_attack_order_rows(records)
+    rule_rows = build_rule_failure_rows(records)
+
+    condition_csv = write_csv(
+        tables_dir / "q1_condition_final_turn_metrics.csv",
+        condition_rows,
+        [
+            "rule_count",
+            "turn_count",
+            "attack_intensity",
+            "per_rule_pass_rate_mean",
+            "per_rule_pass_rate_std",
+            "per_rule_pass_rate_n",
+            "perfect_success_mean",
+            "perfect_success_std",
+            "perfect_success_n",
+            "targeted_rule_success_mean",
+            "targeted_rule_success_std",
+            "targeted_rule_success_n",
+            "non_target_failure_mean",
+            "non_target_failure_std",
+            "non_target_failure_n",
+        ],
+    )
+    order_csv = write_csv(
+        tables_dir / "q1_attack_order_final_turn_metrics.csv",
+        order_rows,
+        [
+            "rule_count",
+            "turn_count",
+            "attack_order_variant",
+            "per_rule_pass_rate_mean",
+            "per_rule_pass_rate_std",
+            "per_rule_pass_rate_n",
+            "perfect_success_mean",
+            "perfect_success_std",
+            "perfect_success_n",
+            "targeted_rule_success_mean",
+            "targeted_rule_success_std",
+            "targeted_rule_success_n",
+            "non_target_failure_mean",
+            "non_target_failure_std",
+            "non_target_failure_n",
+        ],
+    )
+    rule_csv = write_csv(
+        tables_dir / "q1_rule_failure_final_turn_metrics.csv",
+        rule_rows,
+        [
+            "rule_id",
+            "rule_count",
+            "turn_count",
+            "attack_intensity",
+            "failed",
+            "total",
+            "failure_rate",
+        ],
+    )
+
+    outputs: dict[str, str] = {
+        "condition_csv": str(condition_csv),
+        "attack_order_csv": str(order_csv),
+        "rule_failure_csv": str(rule_csv),
+        "strict_success_figure": str(plot_q1_strict_success(condition_rows, figures_dir)),
+        "old_vs_strict_figure": str(plot_old_vs_strict(condition_rows, figures_dir)),
+        "strict_gap_heatmap": str(plot_benign_adversarial_gap(condition_rows, figures_dir)),
+        "attack_order_figure": str(plot_attack_order(order_rows, figures_dir)),
+        "non_target_failure_heatmap": str(plot_non_target_failure(condition_rows, figures_dir)),
+        "rule_failure_t15_heatmap": str(plot_rule_failure(rule_rows, figures_dir)),
+    }
+
+    summary = build_summary(
+        records=records,
+        condition_rows=condition_rows,
+        order_rows=order_rows,
+        trace_counts=trace_counts,
+        judge_audit=judge_audit,
+        outputs=outputs,
+    )
+    summary_json = output_dir / "q1_visualization_summary.json"
+    summary_json.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    outputs["summary_json"] = str(summary_json)
+    summary["outputs"] = outputs
+    summary_md = write_markdown_summary(output_dir / "q1_visualization_summary.md", summary)
+    outputs["summary_markdown"] = str(summary_md)
+    summary_json.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+
+    print(f"Loaded records: {len(records)}")
+    print(f"Trace rows: {trace_counts['rows']}")
+    print(f"Wrote output dir: {output_dir}")
+    for key, value in outputs.items():
+        print(f"{key}: {value}")
+
