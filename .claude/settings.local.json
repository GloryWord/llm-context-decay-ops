{
    "permissions": {
        "defaultMode": "bypassPermissions",
        "allow": [
            "Bash(*)",
            "Write(*)",
            "Edit(*)",
            "Read(*)",
            "WebFetch",
            "WebSearch"
        ],
        "deny": [
            "Bash(rm -rf *)",
            "Bash(sudo *)"
        ]
    }
}